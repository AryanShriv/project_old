{
  "expo": {
    "name": "G(old)",
    "slug": "project_old",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/2AM.png",
    "scheme": "projectold",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1C18",
        "foregroundImage": "./assets/2AM.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.aryanshriv.project_old"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/2AM.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/2AM.png",
          "color": "#D4AF37",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/2AM.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8",
          "dark": {
            "image": "./assets/2AM.png",
            "backgroundColor": "#1C1C18"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0e2a93e-509b-4e7f-8297-fca33039fa08"
      }
    }
  }
}
